<IfModule mod_rewrite.c>
    RewriteEngine On

    # Let the api/ directory handle its own requests — do not touch them here.
    RewriteRule ^api(/.*)?$ - [L]

    # React SPA fallback: every non-file, non-directory request gets index.html
    # so that client-side routing (react-router-dom) handles the URL.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>

# Cache hashed assets for 1 year (content-hash in filename = safe to cache forever)
<IfModule mod_expires.c>
    ExpiresActive On
    <FilesMatch "-[A-Za-z0-9_-]{6,12}\.(js|css|woff2?|ttf|eot)$">
        ExpiresDefault "access plus 1 year"
    </FilesMatch>
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|avif)$">
        ExpiresDefault "access plus 1 month"
    </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "-[A-Za-z0-9_-]{6,12}\.(js|css|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|avif)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>
