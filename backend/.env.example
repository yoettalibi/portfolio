APP_NAME=ET-TALIBI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ettalibi
DB_USERNAME=root
DB_PASSWORD=

# Use "file" on shared hosting — sessions stored in storage/framework/sessions/
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=null

CACHE_STORE=file

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# For local dev use MAIL_MAILER=log to send to the log file instead of a real server.
# For production, set MAIL_MAILER=resend and provide RESEND_API_KEY.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Get a free API key at https://resend.com
RESEND_API_KEY=

# Admin account created by AdminSeeder (php artisan db:seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
